{
  "agents": {
    "defaults": {
      "workspace": "~/.nanobot/workspace",
      "plan_and_solve": true,
      "search_enhanced_planning": {
        "enable": true,
        "max_results": 5,
        "timeout": 120,
        "search_on_replan": false,
        "max_purified_chars": 2000
      },
      "max_subagent_depth": 2,
      "model": "your model here",
      "provider": "auto",
      "maxTokens": 65536,
      "contextWindowTokens": 1000000,
      "contextBlockLimit": null,
      "temperature": 0.1,
      "maxToolIterations": 200,
      "maxToolResultChars": 16000,
      "providerRetryMode": "standard",
      "reasoningEffort": null,
      "timezone": "UTC",
      "unifiedSession": false,
      "disabledSkills": [],
      "idleCompactAfterMinutes": 0,
      "dream": {
        "intervalH": 2,
        "modelOverride": null,
        "maxBatchSize": 20,
        "maxIterations": 15,
        "annotateLineAges": true
      },
      "skill_autogen": {
        "enable": true,
        "nudge_interval": 10,
        "max_iterations": 8
      }
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
