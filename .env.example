# LLM API配置
# 使用DashScope服务
DASHSCOPE_API_KEY=your_dashscope_api_key

# 或者使用OpenAI兼容API服务
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE=https://api.openai.com/v1

# VLM模型配置(用于图像理解)
VLM_MODEL_NAME=qwen-vl-max
VLM_API_KEY=your_vlm_api_key
VLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 代码执行配置
CODE_EXECUTOR_TIMEOUT=60

# Planning配置
# 单步 TIR (Tool-Integrated Reasoning) 循环最大次数
MAX_TIR_LOOPS=5

# ReAct 执行模式
# EXECUTION_MODE=auto           # auto(双层模式: Planning+ReAct), react(纯ReAct), planning(纯Planning)
# REACT_MAX_ITERATIONS=10       # ReAct 最大迭代次数
# MAX_REACT_PER_STEP=5          # 双层模式下每步ReAct最大迭代次数

# Prompt配置
# PROMPT_VERSION=default
# PROMPTS_DIR=prompts
